{
  "name": "transvela",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "wrangler pages dev public",
    "db:migrate:local": "wrangler d1 execute DB --local --file=migrations/0001_init.sql",
    "db:migrate:remote": "wrangler d1 execute DB --remote --file=migrations/0001_init.sql",
    "deploy": "wrangler pages deploy public"
  },
  "devDependencies": {
    "wrangler": "^4.111.0"
  }
}
